{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "lib",
    "rootDir": "..",
    "sourceMap": false
  },
  "include": ["src/**/*", "../backend/src/**/*"],
  "exclude": ["node_modules", "lib", "../backend/dist"]
}
