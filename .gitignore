# Dependencies
node_modules/
**/node_modules/

# Build artifacts
dist/
build/
**/dist/
**/build/
*.tsbuildinfo

# Environment / secrets (keep `.env.example` tracked)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Prisma generated files (regenerate with `npx prisma generate`)
**/node_modules/.prisma/

# Firebase service account & sensitive keys
**/*service-account*.json
**/firebase-adminsdk*.json

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime caches
.vite/
.cache/
coverage/

# macOS
.AppleDouble
.LSOverride
