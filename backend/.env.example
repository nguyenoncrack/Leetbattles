# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codeclash?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS — comma separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"

# LeetCode fetching
# "live" hits the real LeetCode GraphQL endpoint (default, recommended).
# "mock" returns deterministic fake data — only useful for isolated tests.
LEETCODE_MODE="live"
LEETCODE_CACHE_MINUTES=30

# Optional — Google OAuth placeholders (not required for email/password auth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Firebase Admin (for verifying Firebase ID tokens from Google sign-in) ---
# Set FIREBASE_PROJECT_ID to enable ID token verification using Google's
# public keys (no service account required for read-only verify).
FIREBASE_PROJECT_ID=""

# For write operations you'll also want a service account. Provide one of:
# 1. FIREBASE_SERVICE_ACCOUNT_JSON — entire service account JSON as a single
#    env string (recommended for platforms like Render/Railway/Fly).
FIREBASE_SERVICE_ACCOUNT_JSON=""
# 2. FIREBASE_SERVICE_ACCOUNT_KEY_PATH — absolute path on disk to JSON file.
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=""
